# PostgreSQL connection string (Railway provides this).
# For connections from outside Railway (e.g. Vercel), use the PUBLIC connection
# string. If you hit SSL errors, append ?sslmode=require to the URL.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require"

# Secret used to sign session cookies (JWT). Use a long random string in production.
AUTH_SECRET="change-me-to-a-long-random-string"
